---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Beat Motivator">
  <header>
    <div class="inner">
      <h1><span>Beat</span> Motivator</h1>
      <p>IIDX Score Tracker — 日々の成長を記録しよう</p>
    </div>
  </header>

  <main>
    <!-- CSV入力 -->
    <section class="input-section">
      <h2>CSV 入力</h2>
      <p>
        <a href="https://p.eagate.573.jp/game/2dx/33/djdata/score_download.html?style=SP"
           target="_blank" rel="noopener">e-amusement CSV</a>
        をテキストエリアに貼り付けるか、空のまま submit でクリップボードから読み込みます。
      </p>
      <textarea id="csv-input" rows="6" placeholder="e-amusement CSV をここに貼り付け..."></textarea>
      <div class="options-row">
        <label>
          <input type="checkbox" id="opt-include-noplay" />
          未プレイ含む
        </label>
        <label>
          フィルタ:
          <select id="opt-level-filter">
            <option value="0">全レベル</option>
            <option value="12">☆12のみ</option>
            <option value="11">☆11のみ</option>
            <option value="10">☆10のみ</option>
          </select>
        </label>
        <label>
          <input type="checkbox" id="opt-heatmap" checked />
          ヒートマップ
        </label>
      </div>
      <div class="input-actions">
        <button id="btn-submit">Submit</button>
        <button id="btn-example" class="secondary-btn" type="button">サンプルCSVで表示 (保存しない)</button>
      </div>
      <div id="submit-result" class="submit-result"></div>
    </section>

    <!-- AI Advisor: 構造化レポート -->
    <section id="advisor-section" style="display:none;">
      <!-- Rank カード -->
      <div id="advisor-rank-card" class="advisor-card" style="display:none;"></div>
      <!-- プレイ統計 -->
      <div id="advisor-summary-card" class="advisor-card" style="display:none;"></div>
      <!-- 注目曲 -->
      <div id="advisor-songs" style="display:none;"></div>
      <!-- AI チャット (折りたたみ) -->
      <div class="advisor-chat-toggle">
        <button id="advisor-toggle-btn" type="button" class="secondary-btn">
          AI に質問する
        </button>
      </div>
      <div id="advisor-container" style="display:none;">
        <iframe
          id="advisor-iframe"
          src="https://beat-advisor.norimiso.workers.dev"
          style="width:100%; height:500px; border:1px solid var(--border-color, #333); border-radius:8px;"
          allow="clipboard-read"
        ></iframe>
      </div>
    </section>

      <!-- Tweet -->
    <section id="tweet-section" style="display:none;">
      <div class="result-actions">
        <a id="tweet-link" class="tweet-link" target="_blank" rel="noopener">Post your IIDX stats</a>
        <button id="copy-tweet-btn" class="secondary-btn" type="button">文面コピー</button>
      </div>
    </section>

    <!-- レベル別統計テーブル -->
    <section id="stats-section" style="display:none;">
      <h2>レベル別統計</h2>
      <div class="scroll-x">
        <table class="stats-table" id="stats-table">
          <thead>
            <tr>
              <th>☆</th>
              <th>Played / Total</th>
              <th>Avg Rate</th>
              <th>MAX-*</th>
              <th>MAX-**</th>
              <th>99%</th>
              <th>98%</th>
              <th>97%</th>
              <th>96%</th>
              <th>95%</th>
              <th>MAX-</th>
              <th>AAA</th>
              <th>AA</th>
              <th>A</th>
            </tr>
          </thead>
          <tbody id="stats-body"></tbody>
        </table>
      </div>
    </section>

    <!-- サマリーカード -->
    <section id="summary-section" style="display:none;">
      <div class="summary-card">
        <h3>全体サマリー</h3>
        <div class="summary-grid">
          <div class="stat">
            <span class="stat-label">プレイ済</span>
            <span class="stat-value" id="sum-played">-</span>
          </div>
          <div class="stat">
            <span class="stat-label">平均スコアレート</span>
            <span class="stat-value" id="sum-rate">-</span>
          </div>
          <div class="stat">
            <span class="stat-label">総合BPI</span>
            <span class="stat-value" id="sum-bpi">-</span>
          </div>
          <div class="stat">
            <span class="stat-label">合計EX SCORE</span>
            <span class="stat-value" id="sum-exscore">-</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 能力値カード -->
    <section id="ability-section" style="display:none;">
      <div class="summary-card">
        <h3>能力値</h3>
        <div class="ability-gauges">
          <div class="ability-gauge">
            <div class="ability-header">
              <span class="ability-name">単発力</span>
              <span class="ability-value" id="ability-single">-</span>
            </div>
            <div class="ability-bar-bg">
              <div class="ability-bar-fill" id="ability-single-bar" style="width:0%"></div>
            </div>
            <span class="ability-desc">上位10曲の精度 (99-100%の微差を拡大)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 全曲リスト (折りたたみ) -->
    <section id="list-section" style="display:none;">
      <details>
        <summary><h2>全曲リスト</h2></summary>
        <details id="song-column-controls" class="column-controls" style="display:none;">
          <summary>表示列</summary>
          <div id="song-column-toggle-grid" class="column-toggle-grid"></div>
        </details>
        <div class="scroll-x">
          <table class="song-table" id="song-table">
            <thead>
              <tr>
                <th data-col="level">☆</th>
                <th data-col="difficulty">Diff</th>
                <th data-col="title">Title</th>
                <th data-col="compactScore">Score</th>
                <th data-col="exscore">EX SCORE</th>
                <th data-col="rate">Rate</th>
                <th data-col="maxminus">MAX-</th>
                <th data-col="bpi">BPI</th>
                <th data-col="miss">Miss</th>
                <th data-col="clear">Clear</th>
                <th data-col="kaiden">皆伝平均(差)</th>
                <th data-col="top">全1(差)</th>
              </tr>
            </thead>
            <tbody id="song-body"></tbody>
          </table>
        </div>
      </details>
    </section>

    <!-- 履歴 -->
    <section id="history-section">
      <details>
        <summary><h2>履歴</h2></summary>
        <div class="history-tools">
          <button id="export-history-btn" class="secondary-btn" type="button">履歴を書き出し</button>
          <button id="import-history-btn" class="secondary-btn" type="button">履歴を読み込む</button>
          <input id="history-import-input" type="file" accept="application/json" hidden>
        </div>
        <div id="history-list" class="history-list">
          <p class="history-empty">まだ履歴がありません</p>
        </div>
      </details>
    </section>
  </main>

  <script>
    // ── State ──
    let currentResults = null;
    let currentSummary = null;
    let currentSourceLabel = '';

    const SONG_COLUMN_DEFS = [
      { key: 'level', label: '☆' },
      { key: 'difficulty', label: 'Diff' },
      { key: 'title', label: 'Title', locked: true },
      { key: 'compactScore', label: 'Score' },
      { key: 'exscore', label: 'EX SCORE' },
      { key: 'rate', label: 'Rate' },
      { key: 'maxminus', label: 'MAX-' },
      { key: 'bpi', label: 'BPI' },
      { key: 'miss', label: 'Miss' },
      { key: 'clear', label: 'Clear' },
      { key: 'kaiden', label: '皆伝' },
      { key: 'top', label: '全1' },
    ];

    const DEFAULT_DESKTOP_COLUMNS = {
      level: true,
      difficulty: true,
      title: true,
      compactScore: false,
      exscore: true,
      rate: true,
      maxminus: true,
      bpi: true,
      miss: true,
      clear: true,
      kaiden: true,
      top: true,
    };

    const DEFAULT_MOBILE_COLUMNS = {
      level: false,
      difficulty: false,
      title: true,
      compactScore: true,
      exscore: false,
      rate: false,
      maxminus: false,
      bpi: true,
      miss: true,
      clear: true,
      kaiden: false,
      top: false,
    };

    // ── DOM refs ──
    const btnSubmit = document.getElementById('btn-submit');
    const btnExample = document.getElementById('btn-example');
    const csvInput = document.getElementById('csv-input');
    const optLevelFilter = document.getElementById('opt-level-filter');
    const optHeatmap = document.getElementById('opt-heatmap');
    const optNoPlay = document.getElementById('opt-include-noplay');
    const submitResult = document.getElementById('submit-result');
    const copyTweetBtn = document.getElementById('copy-tweet-btn');
    const exportHistoryBtn = document.getElementById('export-history-btn');
    const importHistoryBtn = document.getElementById('import-history-btn');
    const historyImportInput = document.getElementById('history-import-input');

    const DEFAULT_SUBMIT_LABEL = 'Submit';
    const DEFAULT_EXAMPLE_LABEL = 'サンプルCSVで表示 (保存しない)';

    function setBusyState({ busy = false, submitLabel = DEFAULT_SUBMIT_LABEL, exampleLabel = DEFAULT_EXAMPLE_LABEL } = {}) {
      btnSubmit.disabled = busy;
      btnExample.disabled = busy;
      btnSubmit.textContent = submitLabel;
      btnExample.textContent = exampleLabel;
    }

    async function fetchAggregate(csv) {
      const res = await fetch('/api/aggregate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ csv }),
      });
      const data = await res.json();
      if (!res.ok || data.error) {
        throw new Error(data.error || '集計に失敗しました');
      }
      return data;
    }

    function applyAggregateData(data, { saveHistory: shouldSaveHistory = true, sourceLabel = '' } = {}) {
      currentResults = data.results;
      currentSummary = data.summary;
      currentSourceLabel = sourceLabel;
      renderAll();
      if (shouldSaveHistory) saveHistory();
      submitResult.textContent = sourceLabel || '集計が完了しました';
      // AI Advisor にデータを送信
      showAdvisor(data);
    }

    // ── AI Advisor 連携 ──
    const advisorSection = document.getElementById('advisor-section');
    const advisorToggleBtn = document.getElementById('advisor-toggle-btn');
    const advisorContainer = document.getElementById('advisor-container');
    const advisorIframe = document.getElementById('advisor-iframe');
    let advisorVisible = false;
    let pendingAdvisorData = null;
    let advisorReady = false;

    // iframe 内の React アプリが ready を通知してきたらデータを送る
    window.addEventListener('message', (event) => {
      console.log('[motivator] postMessage received:', event.data?.type, 'from:', event.origin);
      if (event.data?.type === 'advisor-ready') {
        console.log('[motivator] advisor-ready! pending:', !!pendingAdvisorData);
        advisorReady = true;
        if (pendingAdvisorData) {
          sendToAdvisor(pendingAdvisorData);
        }
      }
    });

    advisorToggleBtn.addEventListener('click', () => {
      advisorVisible = !advisorVisible;
      advisorContainer.style.display = advisorVisible ? '' : 'none';
      advisorToggleBtn.textContent = advisorVisible ? 'AI Advisor を閉じる' : 'AI Advisor を開く';
      // 開いた直後にも送信を試みる (ready だがデータ未送信の場合)
      if (advisorVisible && pendingAdvisorData && advisorReady) {
        console.log('[motivator] toggle open -> sending data');
        sendToAdvisor(pendingAdvisorData);
      }
    });

    function showAdvisor(data) {
      advisorSection.style.display = '';
      const context = buildAdvisorContext(data);
      pendingAdvisorData = context;

      // 1. ネイティブ構造化レポートを描画
      renderReport(context, data);

      // 2. iframe にもデータを送る (AI チャット用)
      if (advisorReady) sendToAdvisor(context);
    }

    function sendToAdvisor(context) {
      const iframe = advisorIframe;
      if (iframe && iframe.contentWindow) {
        console.log('[motivator] sendToAdvisor: posting to iframe, played=', context.summary.playedCharts);
        iframe.contentWindow.postMessage(
          { type: 'advisor-context', context },
          'https://beat-advisor.norimiso.workers.dev'
        );
      } else {
        console.log('[motivator] sendToAdvisor: iframe not available');
      }
    }

    function buildAdvisorContext(data) {
      const summary = data.summary;
      const results = data.results || [];

      // レベル別統計を AdvisorContext.levelStats 形式に変換
      const levelStats = (summary.levelStats || []).map(s => {
        const played = results.filter(r => r.level === s.level && r.exScore > 0);
        // クリアランプ分布を計算
        const lampCount = (type) => played.filter(r => r.clearType === type).length;
        const djCount = (dj) => played.filter(r => r.djLevel === dj).length;
        return {
          level: s.level,
          total: s.total,
          played: s.played,
          playRate: s.total > 0 ? s.played / s.total : 0,
          averageScoreRate: s.averageRate,
          clearLampDistribution: {
            fc: lampCount('FULLCOMBO CLEAR'),
            exh: lampCount('EX HARD CLEAR'),
            hard: lampCount('HARD CLEAR'),
            clear: lampCount('CLEAR'),
            easy: lampCount('EASY CLEAR'),
            assist: lampCount('ASSIST CLEAR'),
            failed: lampCount('FAILED'),
            noplay: s.total - s.played,
          },
          djLevelDistribution: {
            aaa: s.aaa,
            aa: s.aa,
            a: s.a,
            other: s.played - s.aaa - s.aa - s.a,
          },
          scoreRateDistribution: {
            pct100: played.filter(r => r.scoreRate >= 1.0).length,
            pct99: s.pct99,
            pct98: s.pct98,
            pct97: s.pct97,
            pct96: s.pct96,
            pct95: s.pct95,
          },
          maxMinus1keta: s.maxMinus1keta,
          maxMinus2keta: s.maxMinus2keta,
        };
      });

      // BPM 分布 (簡易版: master データがクライアントにないので results から推定)
      // Note: results には BPM 情報がない → 空配列で初期化、将来 master API から取得
      const bpmDistribution = [];

      // ソフラン統計 (同上)
      const soflanStats = { totalSoflan: 0, playedSoflan: 0, averageScoreRate: 0 };

      // 注目曲
      const playedResults = results.filter(r => r.exScore > 0);
      const sortedByRate = [...playedResults].sort((a, b) => b.scoreRate - a.scoreRate);
      const sortedByRateAsc = [...playedResults].sort((a, b) => a.scoreRate - b.scoreRate);

      // AI に送る曲データ: 全曲ではなく、カテゴリ別に注目すべき曲だけ抽出
      const compact = (r) => ({
        t: r.title, d: r.difficulty, lv: r.level,
        sr: Math.round(r.scoreRate * 10000) / 100,
        cl: r.clearType.replace(' CLEAR','').replace('FULLCOMBO','FC').replace('EX HARD','EXH'),
        dj: r.djLevel,
        bp: r.bpi !== null ? Math.round(r.bpi * 10) / 10 : null,
        mc: r.missCount,
      });

      // ☆12 のカテゴリ別
      const lv12 = playedResults.filter(r => r.level === 12);
      const lv11 = playedResults.filter(r => r.level === 11);

      const notableSongs = {
        // スコア上位10 (得意曲)
        lv12_best: lv12.sort((a,b) => b.scoreRate - a.scoreRate).slice(0, 10).map(compact),
        // スコア下位10 (苦手曲)
        lv12_worst: lv12.filter(r => r.scoreRate > 0).sort((a,b) => a.scoreRate - b.scoreRate).slice(0, 10).map(compact),
        // FAILED している曲 (挑戦中)
        lv12_failed: results.filter(r => r.level === 12 && r.clearType === 'FAILED').slice(0, 10).map(compact),
        // AAA に近い曲 (AA 上位)
        almostAAA: playedResults
          .filter(r => r.djLevel === 'AA' && r.scoreRate >= 0.85)
          .sort((a,b) => b.scoreRate - a.scoreRate).slice(0, 10).map(compact),
        // FC に近い曲 (ミス1-5)
        almostFC: playedResults
          .filter(r => r.missCount !== null && r.missCount > 0 && r.missCount <= 5 && r.clearType !== 'FULLCOMBO CLEAR')
          .sort((a,b) => (a.missCount||99) - (b.missCount||99)).slice(0, 10).map(compact),
        // ☆11 のスコア上位/下位 (地力帯)
        lv11_best: lv11.sort((a,b) => b.scoreRate - a.scoreRate).slice(0, 5).map(compact),
        lv11_worst: lv11.filter(r => r.scoreRate > 0).sort((a,b) => a.scoreRate - b.scoreRate).slice(0, 5).map(compact),
      };

      return {
        summary: {
          totalCharts: summary.totalCharts,
          playedCharts: summary.playedCharts,
          averageScoreRate: summary.averageScoreRate,
          averageBpi: summary.averageBpi,
          estimatedRank: 0, // beat-advisor 側で計算
          ability: summary.ability,
        },
        levelStats,
        bpmDistribution,
        soflanStats,
        taggedChartStats: {},
        notableSongs,
      };
    }

    function simplifyScore(r) {
      return {
        title: r.title,
        difficulty: r.difficulty,
        level: r.level,
        exScore: r.exScore,
        scoreRate: r.scoreRate,
        clearType: r.clearType,
        djLevel: r.djLevel,
        missCount: r.missCount,
        bpi: r.bpi,
      };
    }

    // ── Rank 推定 (クライアント側) ──
    const LAMP_ORDER = ['NO PLAY','FAILED','ASSIST CLEAR','EASY CLEAR','CLEAR','HARD CLEAR','EX HARD CLEAR','FULLCOMBO CLEAR'];
    const RANK_THRESHOLDS = [
      { rank:0, label:'級位', criteria:[{type:'clearRate',level:3,rate:0.3,lampType:'CLEAR',label:'☆3の30%以上クリア'}] },
      { rank:1, label:'初段', criteria:[{type:'clearRate',level:5,rate:0.3,lampType:'CLEAR',label:'☆5の30%以上クリア'}] },
      { rank:2, label:'二段', criteria:[{type:'clearRate',level:6,rate:0.3,lampType:'CLEAR',label:'☆6の30%以上クリア'}] },
      { rank:3, label:'三段', criteria:[{type:'clearRate',level:7,rate:0.3,lampType:'CLEAR',label:'☆7の30%以上クリア'}] },
      { rank:4, label:'四段', criteria:[{type:'clearRate',level:8,rate:0.3,lampType:'CLEAR',label:'☆8の30%以上クリア'}] },
      { rank:5, label:'五段', criteria:[{type:'clearRate',level:8,rate:0.5,lampType:'CLEAR',label:'☆8の50%以上クリア'},{type:'clearRate',level:9,rate:0.1,lampType:'CLEAR',label:'☆9の10%以上クリア'}] },
      { rank:6, label:'六段', criteria:[{type:'clearRate',level:9,rate:0.3,lampType:'CLEAR',label:'☆9の30%以上クリア'}] },
      { rank:7, label:'七段', criteria:[{type:'clearRate',level:9,rate:0.6,lampType:'CLEAR',label:'☆9の60%以上クリア'},{type:'clearRate',level:10,rate:0.1,lampType:'CLEAR',label:'☆10の10%以上クリア'}] },
      { rank:8, label:'八段', criteria:[{type:'clearRate',level:10,rate:0.4,lampType:'CLEAR',label:'☆10の40%以上クリア'}] },
      { rank:9, label:'九段', criteria:[{type:'clearRate',level:10,rate:0.6,lampType:'CLEAR',label:'☆10の60%以上クリア'},{type:'clearRate',level:11,rate:0.1,lampType:'CLEAR',label:'☆11の10%以上クリア'}] },
      { rank:10, label:'十段', criteria:[{type:'clearRate',level:11,rate:0.4,lampType:'CLEAR',label:'☆11の40%以上クリア'},{type:'clearRate',level:12,rate:0.05,lampType:'EASY_CLEAR',label:'☆12にEasy以上がちらほら'}] },
      { rank:11, label:'中伝', criteria:[{type:'clearRate',level:12,rate:0.4,lampType:'HARD_CLEAR',label:'☆12の40%以上HARD'},{type:'djLevelRate',level:12,rate:0.02,djLevel:'AAA',label:'☆12にAAAが数曲ある'}] },
      { rank:12, label:'皆伝', criteria:[{type:'clearRate',level:12,rate:0.7,lampType:'HARD_CLEAR',label:'☆12の70%以上HARD'},{type:'djLevelRate',level:12,rate:0.1,djLevel:'AAA',label:'☆12の10%以上AAA'}] },
      { rank:13, label:'上位皆伝', criteria:[{type:'clearRate',level:12,rate:0.95,lampType:'HARD_CLEAR',label:'☆12の95%以上HARD'},{type:'djLevelRate',level:12,rate:0.5,djLevel:'AAA',label:'☆12の50%以上AAA'}] },
      { rank:14, label:'最上位皆伝', criteria:[{type:'clearRate',level:12,rate:0.95,lampType:'EX_HARD_CLEAR',label:'☆12の95%以上EXH'},{type:'djLevelRate',level:12,rate:0.8,djLevel:'AAA',label:'☆12の80%以上AAA'}] },
      { rank:15, label:'トッププレイヤー', criteria:[{type:'clearRate',level:12,rate:0.95,lampType:'EX_HARD_CLEAR',label:'☆12の95%以上EXH'},{type:'djLevelRate',level:12,rate:0.95,djLevel:'AAA',label:'☆12の95%以上AAA'}] },
    ];

    function estimateRankClient(levelStats) {
      const statsMap = new Map();
      for (const s of levelStats) statsMap.set(s.level, s);

      function evalCriterion(c) {
        const s = statsMap.get(c.level);
        if (!s || s.total === 0) return { label: c.label, met: false, actual: 0, required: c.rate };
        let actual = 0;
        if (c.type === 'clearRate' && c.lampType) {
          const d = s.clearLampDistribution;
          const li = LAMP_ORDER.indexOf(c.lampType);
          const counts = [d.noplay, d.failed, d.assist, d.easy, d.clear, d.hard, d.exh, d.fc];
          let cl = 0; for (let i = li; i < counts.length; i++) cl += counts[i];
          actual = cl / s.total;
        } else if (c.type === 'djLevelRate' && c.djLevel) {
          const d = s.djLevelDistribution;
          if (c.djLevel === 'AAA') actual = d.aaa / s.total;
          else if (c.djLevel === 'AA') actual = (d.aaa + d.aa) / s.total;
        }
        return { label: c.label, met: actual >= c.rate, actual, required: c.rate };
      }

      const sorted = [...RANK_THRESHOLDS].sort((a,b) => b.rank - a.rank);
      for (let i = 0; i < sorted.length; i++) {
        const rd = sorted[i];
        const results = rd.criteria.map(evalCriterion);
        const met = results.filter(r => r.met);
        const unmet = results.filter(r => !r.met);
        if (met.length > 0) {
          const next = i > 0 ? sorted[i-1] : null;
          return { rank: rd.rank, label: rd.label, met, unmet,
            nextLabel: next?.label, nextGoals: next ? next.criteria.map(evalCriterion) : [] };
        }
      }
      return { rank: 0, label: '級位', met: [], unmet: [], nextLabel: null, nextGoals: [] };
    }

    // ── ネイティブレポート描画 ──
    function renderReport(context, data) {
      const pct = v => (v * 100).toFixed(1) + '%';
      const rr = estimateRankClient(context.levelStats);
      const ns = context.notableSongs || {};

      // Rank カード
      const rankEl = document.getElementById('advisor-rank-card');
      let rankHtml = `<div class="rank-header"><div class="rank-badge">Rank ${rr.rank}</div><div class="rank-label">${rr.label}</div></div>`;
      if (rr.met.length) {
        rankHtml += '<h4>達成済み</h4>';
        rr.met.forEach(c => { rankHtml += `<div class="criterion met">✓ ${c.label} (${pct(c.actual)})</div>`; });
      }
      if (rr.unmet.length) {
        rankHtml += '<h4>改善ポイント</h4>';
        rr.unmet.forEach(c => {
          const w = Math.min(100, (c.actual / c.required) * 100);
          rankHtml += `<div class="criterion unmet">✗ ${c.label}<span class="criterion-bar"><span class="criterion-fill" style="width:${w}%"></span></span><span class="criterion-pct">${pct(c.actual)} / ${pct(c.required)}</span></div>`;
        });
      }
      if (rr.nextLabel && rr.nextGoals.length) {
        rankHtml += `<div class="next-rank-section"><h4>次の目標: ${rr.nextLabel}</h4>`;
        rr.nextGoals.forEach(c => {
          rankHtml += `<div class="criterion ${c.met?'met':'unmet'}">${c.met?'✓':'✗'} ${c.label}${!c.met?' ('+pct(c.actual)+')':''}</div>`;
        });
        rankHtml += '</div>';
      }
      rankEl.innerHTML = rankHtml;
      rankEl.style.display = '';

      // サマリーカード
      const sumEl = document.getElementById('advisor-summary-card');
      const s = context.summary;
      sumEl.innerHTML = `<h3>プレイ統計</h3><div class="stat-row">
        <div class="stat-item"><span class="stat-value">${s.playedCharts}</span><span class="stat-label">プレイ曲</span></div>
        <div class="stat-item"><span class="stat-value">${pct(s.averageScoreRate)}</span><span class="stat-label">平均スコア</span></div>
        <div class="stat-item"><span class="stat-value">${s.averageBpi?.toFixed(1) ?? 'N/A'}</span><span class="stat-label">平均BPI</span></div>
        <div class="stat-item"><span class="stat-value">${s.ability?.singleNote?.toFixed(1) ?? 'N/A'}</span><span class="stat-label">単発力</span></div>
      </div>`;
      sumEl.style.display = '';

      // 注目曲カード
      const songsEl = document.getElementById('advisor-songs');
      let songsHtml = '';
      const songCard = (title, songs, color) => {
        if (!songs || !songs.length) return '';
        let h = `<div class="advisor-card song-card"><h3 class="song-card-title" style="border-left:3px solid ${color}">${title}</h3>`;
        songs.forEach(s => {
          h += `<div class="song-row"><span class="song-title">${s.t}</span><span class="song-meta">${s.d}</span><span class="song-rate">${s.sr}%</span><span class="song-lamp">${s.cl}</span></div>`;
        });
        return h + '</div>';
      };
      songsHtml += songCard('☆12 得意曲', ns.lv12_best, '#00ff88');
      songsHtml += songCard('☆12 課題曲', ns.lv12_worst, '#ffaa00');
      songsHtml += songCard('AAA まであと少し', ns.almostAAA, '#00d4ff');
      songsHtml += songCard('FC まであと少し', ns.almostFC, '#00d4ff');
      songsEl.innerHTML = songsHtml;
      songsEl.style.display = '';
    }

    // ── Submit ──
    btnSubmit.addEventListener('click', async () => {
      let csv = csvInput.value;
      if (!csv && navigator.clipboard) {
        try {
          csv = await navigator.clipboard.readText();
        } catch {
          alert('クリップボードの読み取りに失敗しました。CSVを直接貼り付けてください。');
          return;
        }
      }
      if (!csv) {
        alert('CSVデータがありません');
        return;
      }

      setBusyState({ busy: true, submitLabel: '集計中...' });
      submitResult.textContent = '';

      try {
        const data = await fetchAggregate(csv);
        applyAggregateData(data, { saveHistory: true, sourceLabel: 'CSVを集計しました' });
      } catch (e) {
        alert('通信エラー: ' + e.message);
      } finally {
        setBusyState();
      }
    });

    btnExample.addEventListener('click', async () => {
      setBusyState({ busy: true, exampleLabel: '読込中...' });
      submitResult.textContent = '';
      try {
        const response = await fetch('/api/example-csv');
        const payload = await response.json();
        if (!response.ok || payload.error) {
          throw new Error(payload.error || 'サンプルCSVの読み込みに失敗しました');
        }
        csvInput.value = payload.csv || '';
        const data = await fetchAggregate(payload.csv || '');
        applyAggregateData(data, { saveHistory: false, sourceLabel: `サンプルCSV (${payload.filename}) を表示しました` });
      } catch (e) {
        alert(e.message);
      } finally {
        setBusyState();
      }
    });

    // ── Options ──
    optHeatmap.addEventListener('change', () => { if (currentSummary) renderStats(); });
    optLevelFilter.addEventListener('change', () => { if (currentResults) renderSongList(); });
    optNoPlay.addEventListener('change', () => { if (currentResults) renderSongList(); });

    // ── Render ──
    function renderAll() {
      renderStats();
      renderSummary();
      renderAbility();
      renderSongList();
      renderTweet();
      renderColumnControls();
      applyColumnVisibility();
    }

    function renderStats() {
      if (!currentSummary) return;
      const stats = currentSummary.levelStats;
      const tbody = document.getElementById('stats-body');
      const heatmap = optHeatmap.checked;
      const HEATMAP_COLOR = '74, 158, 255';

      let html = '';
      for (const s of stats) {
        html += '<tr>';
        html += `<td style="text-align:left;font-weight:600;">☆${s.level}</td>`;
        html += `<td>${s.played} / ${s.total}</td>`;
        html += `<td style="text-align:right;">${(s.averageRate * 100).toFixed(3)}%</td>`;

        const cells = [
          s.maxMinus1keta, s.maxMinus2keta,
          s.pct99, s.pct98, s.pct97, s.pct96, s.pct95,
          s.maxMinus, s.aaa, s.aa, s.a,
        ];
        for (const val of cells) {
          const alpha = s.total > 0 ? val / s.total : 0;
          const bg = heatmap
            ? `background-color: rgba(${HEATMAP_COLOR}, ${alpha.toFixed(3)});`
            : '';
          html += `<td style="${bg}">${val}</td>`;
        }
        html += '</tr>';
      }
      tbody.innerHTML = html;
      document.getElementById('stats-section').style.display = '';
    }

    function renderAbility() {
      if (!currentSummary?.ability) {
        document.getElementById('ability-section').style.display = 'none';
        return;
      }
      const a = currentSummary.ability;

      document.getElementById('ability-single').textContent = a.singleNote.toFixed(1);
      document.getElementById('ability-single-bar').style.width = a.singleNote.toFixed(1) + '%';

      document.getElementById('ability-section').style.display = '';
    }

    function isMobileLayout() {
      return window.matchMedia('(max-width: 700px)').matches;
    }

    function getColumnPrefsKey() {
      return 'beat-motivator-columns-v1';
    }

    function loadColumnPrefs() {
      try {
        const raw = localStorage.getItem(getColumnPrefsKey());
        return raw ? JSON.parse(raw) : {};
      } catch {
        return {};
      }
    }

    function getActiveColumnPrefs() {
      return {
        ...(isMobileLayout() ? DEFAULT_MOBILE_COLUMNS : DEFAULT_DESKTOP_COLUMNS),
        ...(loadColumnPrefs() || {}),
        title: true,
      };
    }

    function saveColumnPrefs(prefs) {
      localStorage.setItem(getColumnPrefsKey(), JSON.stringify(prefs));
    }

    function renderColumnControls() {
      const root = document.getElementById('song-column-controls');
      const grid = document.getElementById('song-column-toggle-grid');
      if (!root || !grid) return;
      const prefs = getActiveColumnPrefs();
      root.style.display = currentResults ? 'block' : 'none';
      grid.innerHTML = SONG_COLUMN_DEFS.map((column) => `
        <label class="column-toggle${column.locked ? ' locked' : ''}">
          <input type="checkbox" data-column-toggle="${column.key}" ${prefs[column.key] ? 'checked' : ''} ${column.locked ? 'disabled' : ''}>
          <span>${column.label}</span>
        </label>
      `).join('');
      grid.querySelectorAll('[data-column-toggle]').forEach((input) => {
        input.addEventListener('change', () => {
          const nextPrefs = { ...loadColumnPrefs(), [input.dataset.columnToggle]: input.checked };
          saveColumnPrefs(nextPrefs);
          applyColumnVisibility();
        });
      });
    }

    function applyColumnVisibility() {
      const prefs = getActiveColumnPrefs();
      document.querySelectorAll('[data-col]').forEach((el) => {
        const key = el.dataset.col;
        const visible = key === 'title' ? true : !!prefs[key];
        el.style.display = visible ? '' : 'none';
      });
    }

    function getCompactScoreText(result) {
      if (!result || result.exScore <= 0) return '-';
      const rate = (result.scoreRate * 100).toFixed(1);
      const maxPart = result.maxMinus === 0 ? '' : `/-${Math.abs(result.maxMinus)}`;
      return `${result.exScore} (${rate}%${maxPart})`;
    }

    function renderSummary() {
      if (!currentSummary) return;
      const s = currentSummary;
      document.getElementById('sum-played').textContent =
        `${s.playedCharts.toLocaleString()} / ${s.totalCharts.toLocaleString()}`;
      document.getElementById('sum-rate').textContent =
        (s.averageScoreRate * 100).toFixed(2) + '%';
      document.getElementById('sum-bpi').textContent =
        s.averageBpi !== null ? s.averageBpi.toFixed(2) : '-';
      document.getElementById('sum-exscore').textContent =
        `${s.totalExScore.toLocaleString()} / ${s.totalMaxScore.toLocaleString()}`;
      document.getElementById('summary-section').style.display = '';
    }

    function renderSongList() {
      if (!currentResults) return;
      const levelFilter = parseInt(optLevelFilter.value, 10);
      const includeNoPlay = optNoPlay.checked;

      let filtered = currentResults;
      if (levelFilter > 0) {
        filtered = filtered.filter(r => r.level === levelFilter);
      }
      if (!includeNoPlay) {
        filtered = filtered.filter(r => r.exScore > 0);
      }

      const tbody = document.getElementById('song-body');
      let html = '';

      for (const r of filtered) {
        const noPlay = r.exScore === 0;
        const rowClass = noPlay ? 'class="no-play"' : '';
        const diffClass = `diff diff-${r.difficulty.toLowerCase()}`;
        const titleClass = `song-title-cell diff-${r.difficulty.toLowerCase()}`;
        const compactScore = getCompactScoreText(r);

        html += `<tr ${rowClass}>`;
        html += `<td data-col="level">☆${r.level}</td>`;
        html += `<td data-col="difficulty"><span class="${diffClass}">${r.difficulty}</span></td>`;
        html += `<td data-col="title" class="${titleClass}">${escHtml(r.title)}</td>`;
        html += `<td data-col="compactScore" class="compact-score-cell">${noPlay ? '-' : compactScore}</td>`;
        html += `<td data-col="exscore">${noPlay ? '-' : r.exScore}</td>`;
        html += `<td data-col="rate">${noPlay ? '-' : (r.scoreRate * 100).toFixed(2) + '%'}</td>`;
        html += `<td data-col="maxminus">${noPlay ? '-' : r.maxMinus}</td>`;
        html += `<td data-col="bpi">${formatBpi(r.bpi)}</td>`;
        html += `<td data-col="miss">${r.missCount !== null ? r.missCount : '-'}</td>`;
        html += `<td data-col="clear">${formatClear(r.clearType)}</td>`;
        html += `<td data-col="kaiden">${formatDiff(r.kaidenDiff, r.kaidenAverage)}</td>`;
        html += `<td data-col="top">${formatDiff(r.topDiff, r.topScore)}</td>`;
        html += '</tr>';
      }

      tbody.innerHTML = html;
      document.getElementById('list-section').style.display = '';
    }

    function renderTweet() {
      if (!currentSummary) return;
      const s = currentSummary;

      // レベル11,12のサマリー行
      let text = '';
      for (const ls of s.levelStats) {
        if (ls.level === 12 || ls.level === 11) {
          text += `☆${ls.level} avg: ${(ls.averageRate * 100).toFixed(2)}% (${ls.played}/${ls.total}) | `;
          text += `max-**: ${ls.maxMinus2keta} / 99%: ${ls.pct99} / 98%: ${ls.pct98} / AAA: ${ls.aaa}\n`;
        }
      }
      text += `\nTotal played: ${s.playedCharts} | avg: ${(s.averageScoreRate * 100).toFixed(2)}%`;
      if (s.averageBpi !== null) {
        text += ` | BPI: ${s.averageBpi.toFixed(2)}`;
      }

      const shareUrl = new URL(window.location.href);
      const finalText = `${text}\n${shareUrl.toString()}\n#beat_motivator`;
      const tweetUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(finalText)}`;

      const link = document.getElementById('tweet-link');
      link.href = tweetUrl;
      document.getElementById('tweet-section').style.display = '';
    }

    // ── History ──
    const HISTORY_KEY = 'beat-motivator-history';
    const MAX_HISTORY = 30;

    function saveHistory() {
      if (!currentResults || !currentSummary) return;

      // スコアがある結果のみ保存 (NO PLAY を除く → localStorage 節約)
      const scores = {};
      for (const r of currentResults) {
        if (r.exScore <= 0) continue;
        const key = `${r.title}__${r.difficulty}`;
        scores[key] = {
          exScore: r.exScore,
          scoreRate: r.scoreRate,
          bpi: r.bpi,
          clearType: r.clearType,
          djLevel: r.djLevel,
          maxMinus: r.maxMinus,
          missCount: r.missCount,
        };
      }

      const entry = {
        id: crypto.randomUUID(),
        date: new Date().toISOString().slice(0, 10),
        submittedAt: new Date().toISOString(),
        summary: currentSummary,
        scores,
      };

      const history = loadHistory();
      history.unshift(entry);
      if (history.length > MAX_HISTORY) history.length = MAX_HISTORY;

      try {
        localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
      } catch {
        // localStorage full → 古いものを削除して再試行
        while (history.length > 5) {
          history.pop();
          try {
            localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
            break;
          } catch { /* continue removing */ }
        }
      }
      renderHistory();
    }

    function loadHistory() {
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (!raw) return [];
        return JSON.parse(raw);
      } catch {
        return [];
      }
    }

    async function copyTweetText() {
      const link = document.getElementById('tweet-link');
      const href = link?.href || '';
      const url = new URL(href);
      const text = url.searchParams.get('text');
      if (!text) {
        alert('共有できる集計結果がありません');
        return;
      }
      await navigator.clipboard.writeText(text);
      submitResult.textContent = '共有文面をコピーしました';
    }

    function exportHistory() {
      const payload = {
        version: 1,
        exportedAt: new Date().toISOString(),
        entries: loadHistory(),
      };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `beat-motivator-history-${new Date().toISOString().slice(0, 10)}.json`;
      link.click();
      URL.revokeObjectURL(url);
    }

    async function importHistory(file) {
      const text = await file.text();
      const payload = JSON.parse(text);
      const entries = Array.isArray(payload?.entries) ? payload.entries : [];
      const merged = new Map(loadHistory().map((entry) => [entry.id, entry]));
      entries.forEach((entry) => {
        if (entry && typeof entry === 'object' && entry.id) merged.set(entry.id, entry);
      });
      localStorage.setItem(HISTORY_KEY, JSON.stringify([...merged.values()]));
      renderHistory();
    }

    function deleteHistory(id) {
      const history = loadHistory().filter(h => h.id !== id);
      localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
      renderHistory();
    }

    function restoreHistory(id) {
      const history = loadHistory();
      const entry = history.find(h => h.id === id);
      if (!entry) return;

      // 履歴はスコアのみ保存しているので、結果テーブルを再構築はできないが
      // サマリーは復元可能
      currentSummary = entry.summary;
      currentResults = null; // 全曲リストは表示不可
      renderStats();
      renderSummary();
      renderAbility();
      document.getElementById('list-section').style.display = 'none';
      document.getElementById('tweet-section').style.display = 'none';

      // アクティブ表示
      document.querySelectorAll('.history-item').forEach(el => el.classList.remove('active'));
      document.querySelector(`[data-history-id="${id}"]`)?.classList.add('active');
    }

    function renderHistory() {
      const history = loadHistory();
      const container = document.getElementById('history-list');

      if (history.length === 0) {
        container.innerHTML = '<p class="history-empty">まだ履歴がありません</p>';
        return;
      }

      let html = '';
      for (const h of history) {
        const s = h.summary;
        const played = s.playedCharts;
        const rate = (s.averageScoreRate * 100).toFixed(2);
        const bpi = s.averageBpi !== null ? s.averageBpi.toFixed(2) : '-';

        html += `<div class="history-item" data-history-id="${h.id}" onclick="restoreHistory('${h.id}')">`;
        html += `<span class="history-date">${h.date}</span>`;
        html += `<span class="history-info"><strong>${played}</strong> played | <strong>${rate}%</strong> avg | BPI <strong>${bpi}</strong></span>`;
        html += `<button class="history-delete" onclick="event.stopPropagation(); deleteHistory('${h.id}')">削除</button>`;
        html += '</div>';
      }
      container.innerHTML = html;
    }

    // expose to global for onclick handlers
    window.restoreHistory = restoreHistory;
    window.deleteHistory = deleteHistory;
    copyTweetBtn.addEventListener('click', () => {
      copyTweetText().catch((error) => alert(error.message || 'コピーに失敗しました'));
    });
    exportHistoryBtn.addEventListener('click', exportHistory);
    importHistoryBtn.addEventListener('click', () => historyImportInput.click());
    historyImportInput.addEventListener('change', async (event) => {
      const file = event.target.files?.[0];
      if (!file) return;
      try {
        await importHistory(file);
        submitResult.textContent = '履歴を読み込みました';
      } catch (error) {
        alert(error.message || '履歴の読み込みに失敗しました');
      } finally {
        event.target.value = '';
      }
    });
    window.addEventListener('resize', () => {
      renderColumnControls();
      applyColumnVisibility();
    });

    // ── Helpers ──
    function escHtml(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function formatBpi(bpi) {
      if (bpi === null || bpi === undefined) return '<span class="bpi-negative">-</span>';
      const val = bpi.toFixed(2);
      if (bpi >= 80) return `<span class="bpi-top">${val}</span>`;
      if (bpi >= 50) return `<span class="bpi-high">${val}</span>`;
      if (bpi >= 0) return `<span class="bpi-mid">${val}</span>`;
      if (bpi >= -15) return `<span class="bpi-low">${val}</span>`;
      return `<span class="bpi-negative">${val}</span>`;
    }

    function formatClear(ct) {
      const map = {
        'FULLCOMBO CLEAR': ['FC', 'clear-fc'],
        'EX HARD CLEAR': ['EXH', 'clear-exh'],
        'HARD CLEAR': ['H', 'clear-hard'],
        'CLEAR': ['N', 'clear-normal'],
        'EASY CLEAR': ['E', 'clear-easy'],
        'ASSIST CLEAR': ['A', 'clear-assist'],
        'FAILED': ['-', 'clear-failed'],
        'NO PLAY': ['-', 'clear-noplay'],
      };
      const [label, cls] = map[ct] ?? ['?', ''];
      return `<span class="${cls}">${label}</span>`;
    }

    function formatDiff(diff, base) {
      if (diff === null || diff === undefined || base === null || base === undefined) return '-';
      const sign = diff >= 0 ? '+' : '';
      const cls = diff >= 0 ? 'positive' : 'negative';
      return `${base} (<span class="${cls}">${sign}${diff}</span>)`;
    }

    // ── Init ──
    renderHistory();
  </script>
</Layout>
